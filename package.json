{
  "name": "cielo",
  "version": "2.4.8",
  "description": "Client para a API 3.0 da Cielo em node.js",
  "main": "dist/index.js",
  "scripts": {
    "test": "jest --coverage",
    "release": "standard-version",
    "postversion": "git push --follow-tags",
    "build": "npx tsc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/banzeh/cielo.git"
  },
  "keywords": [
    "cielo",
    "cartao",
    "credito",
    "debito",
    "mastercard",
    "visa",
    "pagamento",
    "pay",
    "recorrencia"
  ],
  "author": "Flavio Takeuchi <flavio@banzeh.com.br>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/banzeh/cielo/issues"
  },
  "homepage": "https://banzeh.github.io/cielo/",
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-typescript": "^7.27.1",
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@types/jest": "^29.5.12",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^8.0.3",
    "jest": "^29.4.3",
    "standard-version": "^9.5.0",
    "tape": "^5.9.0",
    "tape-promise": "^4.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/node": "^22.0.0",
    "camelcase-keys": "^6.2.2",
    "typed-rest-client": "^1.8.11"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "overrides": {
    "tmp": "^0.2.5"
  }
}
