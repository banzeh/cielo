{
  "name": "cielo",
  "version": "2.4.8",
  "description": "Client para a API 3.0 da Cielo em node.js",
  "main": "dist/index.js",
  "scripts": {
    "test": "jest --coverage",
    "release": "standard-version",
    "postversion": "git push --follow-tags",
    "build": "npx tsc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/banzeh/cielo.git"
  },
  "keywords": [
    "cielo",
    "cartao",
    "credito",
    "debito",
    "mastercard",
    "visa",
    "pagamento",
    "pay",
    "recorrencia"
  ],
  "author": "Flavio Takeuchi <flavio@banzeh.com.br>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/banzeh/cielo/issues"
  },
  "homepage": "https://banzeh.github.io/cielo/",
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.17",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^8.0.3",
    "jest": "^30.3.0",
    "standard-version": "^9.5.0",
    "tape": "^5.9.0",
    "tape-promise": "^4.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "camelcase-keys": "^6.2.2"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "overrides": {
    "tmp": "^0.2.5",
    "brace-expansion": "^1.1.13",
    "handlebars": "^4.7.9",
    "lodash": "^4.18.1",
    "picomatch": "^2.3.2"
  }
}
